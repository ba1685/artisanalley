generator client {
  provider   = "prisma-client-js"
  engineType = "library" 
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // CRITICAL: Kept this for your Vercel deployment
}

enum Role {
  CUSTOMER
  ARTISAN
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  role         Role      @default(CUSTOMER) 
  
  profileImage String?
  bio          String?

  artworks     Artwork[] @relation("ArtisanArtworks") 
  orders       Order[]   @relation("CustomerOrders")  
  
  createdAt    DateTime  @default(now())
}

model Artwork {
  id          String   @id @default(cuid())
  title       String
  description String?
  price       Float    @default(0)
  imageUrl    String?  
  category    String   @default("All Crafts") 
  
  artisanId   String
  author      User     @relation("ArtisanArtworks", fields: [artisanId], references: [id])
  
  // UPDATED: Now relates to OrderItem instead of Order directly
  orderItems  OrderItem[]
  
  isSold      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Order {
  id              String   @id @default(cuid())
  
  userId          String
  customer        User     @relation("CustomerOrders", fields: [userId], references: [id])
  
  // FIXED: Added @default(0) to bypass the migration error safely
  total           Float    @default(0) 
  status          String   @default("PROCESSING") // UPDATED: Changed default from COMPLETED
  trackingNumber  String?  // NEW: To show delivery status on profile
  
  shippingAddress String
  city            String
  postalCode      String
  
  // NEW: A single order can now have multiple items inside it
  items           OrderItem[]
  
  createdAt       DateTime @default(now())
}

// NEW MODEL: Represents a single piece of art inside a customer's cart/order
model OrderItem {
  id        String   @id @default(cuid())
  
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  artworkId String
  artwork   Artwork  @relation(fields: [artworkId], references: [id])
  
  price     Float    // We store the price here in case the artisan changes the price later!
}