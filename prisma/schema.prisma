generator client {
  provider   = "prisma-client-js"
  engineType = "library" 
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ARTISAN
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(CUSTOMER) 
  
  // Relations
  artworks  Artwork[] @relation("ArtisanArtworks") // Artworks they created
  orders    Order[]   @relation("CustomerOrders")  // Artworks they purchased
  
  createdAt DateTime  @default(now())
}

model Artwork {
  id          String   @id @default(cuid())
  title       String
  description String?
  price       Float    @default(0)
  imageUrl    String?  
  category    String   @default("All Crafts") 
  
  // Relation to User (The Artisan)
  artisanId   String
  author      User     @relation("ArtisanArtworks", fields: [artisanId], references: [id])
  
  // Relation to Orders (The Purchases)
  orders      Order[]
  
  createdAt   DateTime @default(now())
}

// NEW: The Customer Purchase Database
model Order {
  id          String   @id @default(cuid())
  
  // Who bought it? (The Customer)
  userId      String
  customer    User     @relation("CustomerOrders", fields: [userId], references: [id])
  
  // What did they buy?
  artworkId   String
  artwork     Artwork  @relation(fields: [artworkId], references: [id])
  
  amount      Float    // Price at the time of purchase
  status      String   @default("COMPLETED")
  
  createdAt   DateTime @default(now())
}